{#
    Vista: users/index.html.twig
#}

{% extends 'base.html.twig' %}

{% block title %}Usuarios
{% endblock %}

{% block body %}

	<div class="container py-5">

		<div class="mx-auto" style="max-width: 1150px;">

			<div class="d-flex justify-content-between align-items-center mb-4">

				<div>
					<h1 class="display-6 fw-light text-dark mb-1" style="letter-spacing: -1px;">
						Usuarios
					</h1>

					<p class="text-secondary mb-0">
						Manejo de usuarios registrados en el sistema
					</p>
				</div>

				<a href="{{ path('app_users_new') }}" class="btn btn-dark rounded-0 px-4 py-2">
					Nuevo Usuario
				</a>

			</div>

			<div class="card border-0 rounded-0 shadow-sm">

				<div class="card-body p-4 border-bottom bg-light">

					<form method="GET" action="{{ path('app_users_index') }}">

						<div class="row g-2 align-items-center">

							<div class="col">

								<input type="text" name="search" value="{{ search }}" class="form-control form-control-lg rounded-0 border-secondary shadow-none" placeholder="Buscar por nombre o email...">

							</div>

							<div class="col-md-3">

								<select name="verified" class="form-select form-select-lg rounded-0 border-secondary shadow-none">
									<option value="">Todos los estados</option>
									<option value="1" {{ verified == '1' ? 'selected' : '' }}>Verificados</option>
									<option value="0" {{ verified == '0' ? 'selected' : '' }}>No verificados</option>
								</select>

							</div>

							<div class="col-auto">

								<button class="btn btn-dark rounded-0 px-4 h-100">
									Buscar
								</button>

							</div>

							<div class="col-auto">

								<a href="{{ path('app_users_index') }}" class="btn btn-outline-secondary rounded-0 px-4 h-100">
									Limpiar
								</a>

							</div>

						</div>

					</form>

				</div>

				<div class="table-responsive">

					<table class="table align-middle mb-0">

						<thead class="border-bottom">

							<tr class="bg-dark">

								<th class="text-black fw-normal border-0 p-3">
									ID
								</th>

								<th class="text-black fw-normal border-0 p-3">
									Nombre
								</th>

								<th class="text-black fw-normal border-0 p-3">
									Email
								</th>

								<th class="text-black fw-normal border-0 p-3">
									Estado
								</th>

								<th class="text-black fw-normal border-0 p-3">
									Password
								</th>

								<th class="text-black fw-normal border-0 p-3 text-end">
									Acciones
								</th>

							</tr>

						</thead>

						<tbody>

							{% for user in users %}

								<tr class="border-top">

									<td class="p-3 text-secondary">
										#{{ user.id }}
									</td>

									<td class="p-3 fw-medium text-dark">
										{{ user.name }}
									</td>

									<td class="p-3 text-secondary">
										{{ user.email }}
									</td>

									<td class="p-3">

										{% if user.emailVerifiedAt %}

											<span class="badge bg-dark rounded-0 px-3 py-2 fw-normal">
												Verificado
											</span>

										{% else %}

											<span class="badge bg-secondary rounded-0 px-3 py-2 fw-normal">
												Pendiente
											</span>

										{% endif %}

									</td>

									<td class="p-3">

										<code class="bg-light text-secondary px-2 py-1">
											{{ user.password|slice(0, 10) }}...
										</code>

									</td>

									<td class="p-3 text-end">

										<a href="{{ path('app_users_show', {'id': user.id}) }}" class="btn btn-sm btn-light border rounded-0 px-3 me-2">
											Ver
										</a>

										<a href="{{ path('app_users_edit', {'id': user.id}) }}" class="btn btn-sm btn-dark rounded-0 px-3">
											Editar
										</a>

									</td>

								</tr>

							{% else %}

								<tr>

									<td colspan="6" class="text-center py-5 text-secondary">

										No se encontraron usuarios

									</td>

								</tr>

							{% endfor %}

						</tbody>

					</table>

				</div>

				<div class="card-footer bg-white border-0 py-4">

					<div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

						<small class="text-secondary">
							Total:
							{{ users.getTotalItemCount }}
							usuarios
						</small>

						<div class="card-footer bg-white border-0 py-4">

							<div class="d-flex justify-content-between align-items-center flex-wrap gap-3">


								{# PAGINACIÓN CUSTOM #}
								{# SE PUEDE USAR EL TEMPLATE DE PAGINACIÓN QUE VIENE CON EL BUNDLE #}

									<nav>

										<ul
										class="pagination pagination-sm mb-0"> {# PREV #}

										{% if users.currentPageNumber > 1 %}

											<li class="page-item">

												<a class="page-link rounded-0 text-dark shadow-none" href="{{ path('app_users_index', { page: users.currentPageNumber - 1, search: search }) }}">

													&laquo;

												</a>

											</li>

										{% endif %}

										{# CALCULAR RANGO #}

										{% set start = users.currentPageNumber - 1 %}
										{% set end = users.currentPageNumber + 1 %}

										{% if start < 1 %}
											{% set start = 1 %}
											{% set end = 3 %}
										{% endif %}

										{% if end > users.pageCount %}
											{% set end = users.pageCount %}
											{% set start = users.pageCount - 2 %}
										{% endif %}

										{% if start < 1 %}
											{% set start = 1 %}
										{% endif %}

										{# NUMEROS #}

										{% for page in start..end %}

											<li class="page-item
																																																																														                        {{ page == users.currentPageNumber ? 'active' : '' }}">

												<a class="page-link rounded-0 shadow-none
																																																																														                            {{ page == users.currentPageNumber
																																																																														                                ? 'bg-dark border-dark text-white'
																																																																														                                : 'text-dark' }}" href="{{ path('app_users_index', { page: page, search: search }) }}">

													{{ page }}

												</a>

											</li>

										{% endfor %}

										{# NEXT #}

										{% if users.currentPageNumber < users.pageCount %}

											<li class="page-item">

												<a class="page-link rounded-0 text-dark shadow-none" href="{{ path('app_users_index', { page: users.currentPageNumber + 1, search: search }) }}">

													&raquo;

												</a>

											</li>

										{% endif %}

									</ul>

								</nav>

							</div>

						</div>

					</div>

				</div>

			</div>

		</div>

	</div>

{% endblock %}
