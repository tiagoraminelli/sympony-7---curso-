<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>
        {% block title %}Welcome!{% endblock %}
    </title>

    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>⚫️</text><text y=%221.3em%22 x=%220.2em%22 font-size=%2276%22 fill=%22%23fff%22>sf</text></svg>">

    {# Bootstrap CSS CDN #}
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    {% block stylesheets %}{% endblock %}

    {% block javascripts %}
        {% block importmap %}
            {{ importmap('app') }}
        {% endblock %}

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
        <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
    {% endblock %}

    {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
    {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
    {% endif %}
</head>

<body class="bg-white">

    <div class="container-fluid">
        <div class="row">

            <!-- Sidebar -->
            <div class="col-auto px-0 bg-dark">
                <div class="d-flex flex-column p-3" style="min-height: 100vh; width: 260px;">
                    <div class="text-center mb-4">
                        <h5 class="text-white fw-light">Inventario</h5>
                        <small class="text-secondary">Sistema de Gestión</small>
                    </div>

                    <hr class="text-secondary">

                    <ul class="nav nav-pills flex-column mb-auto">
                        <li class="nav-item">
                            <a href="{{ path('app_home') }}" class="nav-link text-white {{ app.request.get('_route') starts with 'app_home' ? 'active' : '' }}">
                                <i class="bi bi-house-door me-2"></i> Dashboard
                            </a>
                        </li>
                    </ul>

                    <div class="small text-secondary mt-3 mb-2">INVENTARIO</div>

                    <ul class="nav nav-pills flex-column">
                        <li class="nav-item">
                            <a href="{{ path('app_productos_index') }}" class="nav-link text-white {{ app.request.get('_route') starts with 'app_productos' ? 'active' : '' }}">
                                <i class="bi bi-box-seam me-2"></i> Productos
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('app_categoria_index') }}" class="nav-link text-white {{ app.request.get('_route') starts with 'app_categoria' ? 'active' : '' }}">
                                <i class="bi bi-tags me-2"></i> Categorías
                            </a>
                        </li>
                        <li class="nav-item">
                            <a href="{{ path('app_proveedores_index') }}" class="nav-link text-white {{ app.request.get('_route') starts with 'app_proveedores' ? 'active' : '' }}">
                                <i class="bi bi-truck me-2"></i> Proveedores
                            </a>
                        </li>
                    </ul>

                    <div class="small text-secondary mt-3 mb-2">COMERCIAL</div>

                    <ul class="nav nav-pills flex-column">
                        <li class="nav-item">
                            <a href="{{ path('app_presupuestos_index') }}" class="nav-link text-white {{ app.request.get('_route') starts with 'app_presupuestos' ? 'active' : '' }}">
                                <i class="bi bi-file-text me-2"></i> Presupuestos
                            </a>
                        </li>
                    </ul>

                    <div class="small text-secondary mt-3 mb-2">SEGURIDAD</div>

                    <ul class="nav nav-pills flex-column">
                        <li class="nav-item">
                            <a href="{{ path('app_users_index') }}" class="nav-link text-white {{ app.request.get('_route') starts with 'app_users' ? 'active' : '' }}">
                                <i class="bi bi-people me-2"></i> Usuarios
                            </a>
                        </li>
                    </ul>

                    <hr class="text-secondary">

                    <ul class="nav nav-pills flex-column">
                        {% if app.user %}
                            <li class="nav-item">
                                <a class="nav-link text-white" href="#">
                                    <i class="bi bi-person-circle me-2"></i> {{ app.user.name ?? app.user.email }}
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-danger" href="#">
                                    <i class="bi bi-box-arrow-right me-2"></i> Cerrar Sesión
                                </a>
                            </li>
                        {% else %}
                            <li class="nav-item">
                                <a class="nav-link text-white" href="#">
                                    <i class="bi bi-box-arrow-in-right me-2"></i> Login
                                </a>
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>

            <!-- Contenido principal -->
            <div class="col bg-white p-4">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <button class="btn btn-outline-secondary rounded-0 d-md-none" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarCollapse">
                        <i class="bi bi-list"></i> Menú
                    </button>
                    <div class="ms-auto">
                        <span class="text-secondary">
                            <i class="bi bi-person"></i> {{ app.user ? app.user.name ?? app.user.email : 'Invitado' }}
                        </span>
                    </div>
                </div>

                {% if breadcrumbs is defined and breadcrumbs|length > 0 %}
                    <nav aria-label="breadcrumb" class="mb-4">
                        <ol class="breadcrumb">
                            <li class="breadcrumb-item">
                                <a href="{{ path('app_home') }}">Inicio</a>
                            </li>
                            {% for crumb in breadcrumbs %}
                                {% if crumb.url %}
                                    <li class="breadcrumb-item">
                                        <a href="{{ crumb.url }}">{{ crumb.label }}</a>
                                    </li>
                                {% else %}
                                    <li class="breadcrumb-item active" aria-current="page">
                                        {{ crumb.label }}
                                    </li>
                                {% endif %}
                            {% endfor %}
                        </ol>
                    </nav>
                {% endif %}

                {% block body %}{% endblock %}

            </div>

        </div>
    </div>

    {{ include('_delete_modal.html.twig') }}

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const deleteModal = document.getElementById('deleteModal');
            const deleteForm = document.getElementById('deleteForm');
            const deleteItemName = document.getElementById('deleteItemName');
            const deleteToken = document.getElementById('deleteToken');

            document.querySelectorAll('[data-delete]').forEach(button => {
                button.addEventListener('click', function (e) {
                    e.preventDefault();

                    const id = this.getAttribute('data-id');
                    const name = this.getAttribute('data-name');
                    let url = this.getAttribute('data-url');
                    const token = this.getAttribute('data-token');

                    url = url.replace('ID_PLACEHOLDER', id);

                    deleteItemName.textContent = name;
                    deleteForm.action = url;
                    deleteToken.value = token;

                    const modal = new bootstrap.Modal(deleteModal);
                    modal.show();
                });
            });
        });
    </script>

    {% block scripts %}{% endblock %}

</body>
</html>
