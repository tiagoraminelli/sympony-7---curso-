{% extends 'base.html.twig' %}

{% block title %}Inicio{% endblock %}

{% block body %}

<div class="container py-5">

    <div class="text-center mb-5">
        <h1 class="display-5 fw-light">
            Sistema de Inventario
        </h1>

        <p class="text-secondary">
            Administración de productos, categorías, proveedores y usuarios
        </p>
    </div>

    <div class="row g-4 mb-5">

        {# Tarjetas de resumen #}

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-0">
                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <div class="text-secondary small">
                                Productos registrados
                            </div>

                            <h2 class="mb-0 fw-light">
                                {{ totalProductos }}
                            </h2>
                        </div>

                        <i class="bi bi-box-seam fs-1 text-secondary"></i>

                    </div>

                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-0">
                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <div class="text-secondary small">
                                Categorías registradas
                            </div>

                            <h2 class="mb-0 fw-light">
                                {{ totalCategorias }}
                            </h2>
                        </div>

                        <i class="bi bi-tags fs-1 text-secondary"></i>

                    </div>

                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-0">
                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <div class="text-secondary small">
                                Proveedores registrados
                            </div>

                            <h2 class="mb-0 fw-light">
                                {{ totalProveedores }}
                            </h2>
                        </div>

                        <i class="bi bi-truck fs-1 text-secondary"></i>

                    </div>

                </div>
            </div>
        </div>

        <div class="col-md-3">
    <div class="card border-0 shadow-sm rounded-0">
        <div class="card-body p-4">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <div class="text-secondary small">
                        Presupuestos
                    </div>
                    <h2 class="mb-0 fw-light">
                        {{ totalPresupuestos ?? 0 }}
                    </h2>
                </div>
                <i class="bi bi-file-text fs-1 text-secondary"></i>
            </div>
        </div>
    </div>
</div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-0">
                <div class="card-body p-4">

                    <div class="d-flex justify-content-between align-items-center">

                        <div>
                            <div class="text-secondary small">
                                Usuarios registrados
                            </div>

                            <h2 class="mb-0 fw-light">
                                {{ totalUsuarios }}
                            </h2>
                        </div>

                        <i class="bi bi-people fs-1 text-secondary"></i>

                    </div>

                </div>
            </div>
        </div>

    </div>

    {# Accesos directos a módulos #}
    <div class="row g-4">

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-0 h-100">
                <div class="card-body p-4">

                    <i class="bi bi-box-seam display-5 text-dark"></i>

                    <h4 class="mt-3">
                        Productos
                    </h4>

                    <p class="text-secondary">
                        Gestionar productos, precios y stock.
                    </p>

                    <a href="{{ path('app_productos_index') }}"
                       class="btn btn-dark rounded-0">
                        Abrir módulo
                    </a>

                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-0 h-100">
                <div class="card-body p-4">

                    <i class="bi bi-tags display-5 text-dark"></i>

                    <h4 class="mt-3">
                        Categorías
                    </h4>

                    <p class="text-secondary">
                        Administrar categorías de productos.
                    </p>

                    <a href="{{ path('app_categoria_index') }}"
                       class="btn btn-dark rounded-0">
                        Abrir módulo
                    </a>

                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-0 h-100">
                <div class="card-body p-4">

                    <i class="bi bi-truck display-5 text-dark"></i>

                    <h4 class="mt-3">
                        Proveedores
                    </h4>

                    <p class="text-secondary">
                        Gestionar proveedores del sistema.
                    </p>

                    <a href="{{ path('app_proveedores_index') }}"
                       class="btn btn-dark rounded-0">
                        Abrir módulo
                    </a>

                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-0 h-100">
                <div class="card-body p-4">

                    <i class="bi bi-people display-5 text-dark"></i>

                    <h4 class="mt-3">
                        Usuarios
                    </h4>

                    <p class="text-secondary">
                        Gestionar usuarios del sistema.
                    </p>

                    <a href="{{ path('app_users_index') }}"
                       class="btn btn-dark rounded-0">
                        Abrir módulo
                    </a>

                </div>
            </div>
        </div>

    </div>

    <div class="row g-4 mt-2">

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-0">
                <div class="card-body p-4">

                    <h5>
                        Acciones rápidas
                    </h5>

                    <div class="d-flex flex-wrap gap-2 mt-3">

                        <a href="{{ path('app_productos_new') }}"
                           class="btn btn-outline-dark rounded-0">
                            Nuevo Producto
                        </a>

                        <a href="{{ path('app_categoria_new') }}"
                           class="btn btn-outline-dark rounded-0">
                            Nueva Categoría
                        </a>

                        <a href="{{ path('app_proveedores_new') }}"
                           class="btn btn-outline-dark rounded-0">
                            Nuevo Proveedor
                        </a>

                        <a href="{{ path('app_users_new') }}"
                           class="btn btn-outline-dark rounded-0">
                            Nuevo Usuario
                        </a>



                    </div>

                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card border-0 shadow-sm rounded-0">
                <div class="card-body p-4">

                    <h5>
                        Herramientas
                    </h5>

                    <div class="d-flex flex-wrap gap-2 mt-3">

                        <a href="{{ path('app_productos_bulk_update') }}"
                           class="btn btn-outline-secondary rounded-0">
                            Edición Masiva
                        </a>

                    </div>

                </div>
            </div>
        </div>

    </div>

</div>

{% endblock %}
