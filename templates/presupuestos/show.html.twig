{% extends 'base.html.twig' %}

{% block title %}Ver Presupuesto{% endblock %}

{% block body %}

    <div class="container py-5">

        <div class="mx-auto" style="max-width: 720px;">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <div>
                    <h1 class="display-6 fw-light text-dark mb-1">
                        Ver Presupuesto
                    </h1>

                    <p class="text-secondary mb-0">
                        Detalles del presupuesto
                    </p>
                </div>

                <a href="{{ path('app_presupuestos_index') }}" class="btn btn-outline-dark rounded-0 px-4">
                    Volver
                </a>

            </div>

            <div class="card border-0 rounded-0 shadow-sm">

                <div class="card-body p-5">

                    <div class="row">

                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold text-dark small text-uppercase">ID</label>
                            <p class="form-control-plaintext">{{ presupuesto.id }}</p>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold text-dark small text-uppercase">Estado</label>
                            <p class="form-control-plaintext">
                                {% set estadoClass = {
                                    'borrador': 'bg-secondary',
                                    'enviado': 'bg-info text-dark',
                                    'aprobado': 'bg-success',
                                    'rechazado': 'bg-danger'
                                } %}
                                <span class="badge {{ estadoClass[presupuesto.estado] ?? 'bg-secondary' }} rounded-0 px-3 py-2">
                                    {{ presupuesto.estado|capitalize }}
                                </span>
                            </p>
                        </div>

                        <div class="col-md-12 mb-4">
                            <label class="form-label fw-semibold text-dark small text-uppercase">Cliente</label>
                            <p class="form-control-plaintext">{{ presupuesto.clienteNombre }}</p>
                        </div>

                        <div class="col-md-12 mb-4">
                            <label class="form-label fw-semibold text-dark small text-uppercase">Teléfono</label>
                            <p class="form-control-plaintext">{{ presupuesto.clienteTelefono ?: '-' }}</p>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold text-dark small text-uppercase">Fecha</label>
                            <p class="form-control-plaintext">{{ presupuesto.fecha ? presupuesto.fecha|date('d/m/Y H:i') : '-' }}</p>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold text-dark small text-uppercase">Usuario</label>
                            <p class="form-control-plaintext">{{ presupuesto.usuario ? presupuesto.usuario.name : '-' }}</p>
                        </div>

                        <div class="col-md-4 mb-4">
                            <label class="form-label fw-semibold text-dark small text-uppercase">Subtotal</label>
                            <p class="form-control-plaintext">${{ presupuesto.subtotal|number_format(2, ',', '.') }}</p>
                        </div>

                        <div class="col-md-4 mb-4">
                            <label class="form-label fw-semibold text-dark small text-uppercase">Descuento</label>
                            <p class="form-control-plaintext">${{ presupuesto.descuento|number_format(2, ',', '.') }}</p>
                        </div>

                        <div class="col-md-4 mb-4">
                            <label class="form-label fw-semibold text-dark small text-uppercase">Total</label>
                            <p class="form-control-plaintext fw-bold">${{ presupuesto.total|number_format(2, ',', '.') }}</p>
                        </div>

                        {% if presupuesto.notas %}
                            <div class="col-md-12 mb-4">
                                <label class="form-label fw-semibold text-dark small text-uppercase">Notas</label>
                                <p class="form-control-plaintext">{{ presupuesto.notas }}</p>
                            </div>
                        {% endif %}

                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold text-dark small text-uppercase">Creado</label>
                            <p class="form-control-plaintext">{{ presupuesto.createdAt ? presupuesto.createdAt|date('d/m/Y H:i') : '-' }}</p>
                        </div>

                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-semibold text-dark small text-uppercase">Actualizado</label>
                            <p class="form-control-plaintext">{{ presupuesto.updatedAt ? presupuesto.updatedAt|date('d/m/Y H:i') : '-' }}</p>
                        </div>

                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-5">

                        <a href="{{ path('app_presupuestos_edit', {'id': presupuesto.id}) }}" class="btn btn-dark rounded-0 px-4 py-2">
                            Editar
                        </a>

                        {{ include('presupuestos/_delete_form.html.twig') }}

                    </div>

                </div>

            </div>

        </div>

    </div>

{% endblock %}
