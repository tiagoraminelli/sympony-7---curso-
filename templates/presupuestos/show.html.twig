{#
    Vista: presupuestos/show.html.twig
    Estilo factura - Una sola página
#}

{% extends 'base.html.twig' %}

{% block title %}Presupuesto #{{ presupuesto.id }}{% endblock %}

{% block body %}

<div class="mx-auto py-4" style="max-width: 800px;">

    {# Botones de acción superiores - No se imprimen #}
    <div class="d-flex justify-content-end gap-2 mb-4 no-print">
        <a href="{{ path('app_presupuestos_print', {'id': presupuesto.id}) }}" target="_blank" class="btn btn-outline-secondary rounded-0 px-4" onclick="setTimeout(function() { window.print(); }, 500);">
    <i class="bi bi-printer"></i> Imprimir
</a>
        <a href="{{ path('app_presupuestos_edit', {'id': presupuesto.id}) }}" class="btn btn-dark rounded-0 px-4">
            <i class="bi bi-pencil-square"></i> Editar
        </a>
        <a href="{{ path('app_presupuestos_index') }}" class="btn btn-outline-dark rounded-0 px-4">
            <i class="bi bi-arrow-left"></i> Volver
        </a>
    </div>

    {# Factura - Optimizada para impresión #}
    <div class="card border-0 shadow-sm rounded-0" style="page-break-inside: avoid;">
        <div class="card-body p-4 p-md-5">

            {# Header #}
            <div class="row mb-4 pb-2 border-bottom">
                <div class="col-7">
                    <h1 class="fw-bold text-dark mb-0" style="font-size: 1.75rem;">PRESUPUESTO</h1>
                    <h2 class="fw-light text-secondary mt-1" style="font-size: 1rem;">N° {{ presupuesto.id }}</h2>
                </div>
                <div class="col-5 text-end">
                    <div class="mb-2">
                        <span class="badge {{ presupuesto.estado == 'aprobado' ? 'bg-success' : presupuesto.estado == 'enviado' ? 'bg-info' : presupuesto.estado == 'rechazado' ? 'bg-danger' : 'bg-secondary' }} rounded-0 px-3 py-2" style="font-size: 0.75rem;">
                            {{ presupuesto.estado|upper }}
                        </span>
                    </div>
                    <div class="text-secondary" style="font-size: 0.8rem;">
                        <div>{{ presupuesto.fecha ? presupuesto.fecha|date('d/m/Y') : '-' }}</div>
                        <div>{{ presupuesto.createdAt ? presupuesto.createdAt|date('H:i') : '' }}</div>
                    </div>
                </div>
            </div>

            {# Datos del cliente #}
            <div class="row mb-4">
                <div class="col-12">
                    <div class="border-bottom pb-1 mb-2">
                        <span class="small text-secondary text-uppercase" style="letter-spacing: 1px;">Cliente</span>
                    </div>
                    <h4 class="fw-semibold mb-1" style="font-size: 1rem;">{{ presupuesto.clienteNombre }}</h4>
                    <p class="text-secondary mb-0" style="font-size: 0.85rem;">Teléfono: {{ presupuesto.clienteTelefono ?: 'No registrado' }}</p>
                    <p class="text-secondary mb-0" style="font-size: 0.85rem;">{{ presupuesto.usuario ? 'Vendedor: ' ~ presupuesto.usuario.name : '' }}</p>
                </div>
            </div>

            {# Tabla de productos #}
            <div class="table-responsive mb-4">
                <table class="table table-sm table-bordered" style="font-size: 0.8rem;">
                    <thead class="bg-light">
                        <tr>
                            <th class="text-center p-2" style="width: 70px;">Cant.</th>
                            <th class="p-2">Producto</th>
                            <th class="text-end p-2" style="width: 100px;">Precio Unit.</th>
                            <th class="text-end p-2" style="width: 100px;">Subtotal</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% set total = 0 %}
                        {% for detalle in presupuesto.detalles %}
                            {% set subtotal = detalle.cantidad * detalle.precioUnitario %}
                            {% set total = total + subtotal %}
                            <tr>
                                <td class="text-center p-2">{{ detalle.cantidad|number_format(3, ',', '.') }}</td>
                                <td class="p-2">{{ detalle.producto ? detalle.producto.nombre : 'Producto no disponible' }}</td>
                                <td class="text-end p-2">${{ detalle.precioUnitario|number_format(2, ',', '.') }}</td>
                                <td class="text-end p-2">${{ subtotal|number_format(2, ',', '.') }}</td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="4" class="text-center p-3 text-secondary">
                                    No hay productos asociados
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>

            {# Totales #}
            <div class="row justify-content-end">
                <div class="col-md-5">
                    <table class="table table-sm table-borderless" style="font-size: 0.9rem;">
                        <tr>
                            <td class="text-secondary border-0 py-1">Subtotal</td>
                            <td class="text-end border-0 py-1">${{ total|number_format(2, ',', '.') }}</td>
                        </tr>
                        <tr>
                            <td class="text-secondary border-0 py-1">Descuento</td>
                            <td class="text-end border-0 py-1">${{ presupuesto.descuento|number_format(2, ',', '.') }}</td>
                        </tr>
                        <tr class="fw-bold">
                            <td class="border-0 pt-2 fs-6">TOTAL</td>
                            <td class="text-end border-0 pt-2 fs-5 text-success">
                                ${{ (total - presupuesto.descuento)|number_format(2, ',', '.') }}
                            </td>
                        </tr>
                    </table>
                </div>
            </div>

            {# Notas #}
            {% if presupuesto.notas %}
                <div class="mt-3 pt-2 border-top">
                    <div class="small text-secondary text-uppercase mb-1" style="letter-spacing: 1px;">Observaciones</div>
                    <p class="mb-0" style="font-size: 0.8rem;">{{ presupuesto.notas }}</p>
                </div>
            {% endif %}

            {# Pie de página #}
            <div class="text-center mt-4 pt-3 border-top">
                <div class="small text-secondary" style="font-size: 0.7rem;">
                    Presupuesto generado electrónicamente - Válido por 30 días
                </div>
            </div>

        </div>
    </div>

</div>

<style>
    @media print {
        .no-print {
            display: none !important;
        }
        .card {
            box-shadow: none !important;
            border: none !important;
            margin: 0 !important;
            padding: 0 !important;
        }
        .card-body {
            padding: 0 !important;
        }
        .badge {
            border: 1px solid #000;
            background: none !important;
            color: #000 !important;
        }
        body {
            margin: 0;
            padding: 0;
        }
        .container, .mx-auto {
            padding: 0 !important;
            margin: 0 !important;
        }
    }
</style>

{% endblock %}
