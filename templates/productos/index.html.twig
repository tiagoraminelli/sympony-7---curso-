{#
    Vista: productos/index.html.twig
#}

{% extends 'base.html.twig' %}

{% block title %}Productos{% endblock %}

{% block body %}

    <div class="container py-5">

        <div class="mx-auto" style="max-width: 1150px;">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <div>
                    <h1 class="display-6 fw-light text-dark mb-1" style="letter-spacing: -1px;">
                        Productos
                    </h1>

                    <p class="text-secondary mb-0">
                        Manejo de productos registrados en el sistema
                    </p>
                </div>

                <a href="{{ path('app_productos_new') }}" class="btn btn-dark rounded-0 px-4 py-2">
                    Nuevo Producto
                </a>

            </div>

            <div class="card border-0 rounded-0 shadow-sm">

                <div class="card-body p-4 border-bottom bg-light">

                    <form method="GET" action="{{ path('app_productos_index') }}">

                        <div class="row g-2 align-items-center">

                            <div class="col">

                                <input type="text" name="search" value="{{ search }}" class="form-control form-control-lg rounded-0 border-secondary shadow-none" placeholder="Buscar por nombre o descripción...">

                            </div>

                            <div class="col-auto">

                                <button class="btn btn-dark rounded-0 px-4 h-100">
                                    Buscar
                                </button>

                            </div>

                        </div>

                    </form>

                </div>

                <div class="table-responsive">

                    <table class="table align-middle mb-0">

                        <thead class="border-bottom">

                            <tr class="bg-dark">

                                <th class="text-white fw-normal border-0 p-3">
                                    ID
                                </th>

                                <th class="text-white fw-normal border-0 p-3">
                                    Nombre
                                </th>

                                <th class="text-white fw-normal border-0 p-3">
                                    Precio
                                </th>

                                <th class="text-white fw-normal border-0 p-3">
                                    Stock
                                </th>

                                <th class="text-white fw-normal border-0 p-3">
                                    Estado
                                </th>

                                <th class="text-white fw-normal border-0 p-3 text-end">
                                    Acciones
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            {% for producto in productos %}

                                <tr class="border-top">

                                    <td class="p-3 text-secondary">
                                        #{{ producto.id }}
                                    </td>

                                    <td class="p-3 fw-medium text-dark">
                                        {{ producto.nombre }}
                                    </td>

                                    <td class="p-3 text-secondary">
                                        ${{ producto.precio }}
                                    </td>

                                    <td class="p-3 text-secondary">
                                        {{ producto.stock }}
                                    </td>

                                    <td class="p-3">

                                        {% if producto.activo %}

                                            <span class="badge bg-dark rounded-0 px-3 py-2 fw-normal">
                                                Activo
                                            </span>

                                        {% else %}

                                            <span class="badge bg-secondary rounded-0 px-3 py-2 fw-normal">
                                                Inactivo
                                            </span>

                                        {% endif %}

                                    </td>

                                    <td class="p-3 text-end">

                                        <a href="{{ path('app_productos_show', {'id': producto.id}) }}" class="btn btn-sm btn-light border rounded-0 px-3 me-2">
                                            Ver
                                        </a>

                                        <a href="{{ path('app_productos_edit', {'id': producto.id}) }}" class="btn btn-sm btn-dark rounded-0 px-3">
                                            Editar
                                        </a>

                                    </td>

                                </tr>

                            {% else %}

                                <tr>

                                    <td colspan="6" class="text-center py-5 text-secondary">

                                        No se encontraron productos

                                    </td>

                                </tr>

                            {% endfor %}

                        </tbody>

                    </table>

                </div>

                <div class="card-footer bg-white border-0 py-4">

                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                        <small class="text-secondary">
                            Total:
                            {{ productos.getTotalItemCount }}
                            productos
                        </small>

                        <div class="card-footer bg-white border-0 py-4">

                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                                <nav>

                                    <ul class="pagination pagination-sm mb-0">

                                       {# acceso a la primera pagina de productos #}

                                        <li class="page-item">

                                            <a class="page-link rounded-0 text-dark shadow-none" href="{{ path('app_productos_index', { page: 1, search: search }) }}">

                                                &laquo;&laquo;

                                            </a>

                                        </li>

                                        {% if productos.currentPageNumber > 1 %}

                                            <li class="page-item">

                                                <a class="page-link rounded-0 text-dark shadow-none" href="{{ path('app_productos_index', { page: productos.currentPageNumber - 1, search: search }) }}">

                                                    &laquo;

                                                </a>

                                            </li>

                                        {% endif %}

                                        {% set start = productos.currentPageNumber - 1 %}
                                        {% set end = productos.currentPageNumber + 1 %}

                                        {% if start < 1 %}
                                            {% set start = 1 %}
                                            {% set end = 3 %}
                                        {% endif %}

                                        {% if end > productos.pageCount %}
                                            {% set end = productos.pageCount %}
                                            {% set start = productos.pageCount - 2 %}
                                        {% endif %}

                                        {% if start < 1 %}
                                            {% set start = 1 %}
                                        {% endif %}

                                        {% for page in start..end %}

                                            <li class="page-item {{ page == productos.currentPageNumber ? 'active' : '' }}">

                                                <a class="page-link rounded-0 shadow-none {{ page == productos.currentPageNumber ? 'bg-dark border-dark text-white' : 'text-dark' }}" href="{{ path('app_productos_index', { page: page, search: search }) }}">

                                                    {{ page }}

                                                </a>

                                            </li>

                                        {% endfor %}

                                        {% if productos.currentPageNumber < productos.pageCount %}

                                            <li class="page-item">

                                                <a class="page-link rounded-0 text-dark shadow-none" href="{{ path('app_productos_index', { page: productos.currentPageNumber + 1, search: search }) }}">

                                                    &raquo;

                                                </a>

                                            </li>

                                        {% endif %}

                                        {# acceso a la ultima pagina de productos #}

                                        <li class="page-item">

                                            <a class="page-link rounded-0 text-dark shadow-none" href="{{ path('app_productos_index', { page: productos.pageCount, search: search }) }}">

                                                &raquo;&raquo;

                                            </a>

                                        </li>

                                    </ul>

                                </nav>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

{% endblock %}
