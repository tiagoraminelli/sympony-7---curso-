{#
    Vista: presupuestos_detalle/index.html.twig
#}

{% extends 'base.html.twig' %}

{% block title %}Detalle de Presupuestos{% endblock %}

{% block body %}

    <div class="mx-auto" style="max-width: 1200px;">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h1 class="display-6 fw-light text-dark mb-1" style="letter-spacing: -1px;">
                    Detalle de Presupuestos
                </h1>
                <p class="text-secondary mb-0">
                    Productos asociados a presupuestos
                </p>
            </div>

            <div class="d-flex gap-2">
                <a href="{{ path('app_presupuestos_detalle_new') }}" class="btn btn-dark rounded-0 px-4 py-2">
                    <i class="bi bi-plus-lg"></i>
                    Nuevo Detalle
                </a>
            </div>

        </div>

        <div class="card border-0 rounded-0 shadow-sm">

            <div class="card-body p-4 border-bottom bg-light">

                <form method="GET" action="{{ path('app_presupuestos_detalle_index') }}">

                    <div class="row g-2 align-items-center">

                        <div class="col-md-5">

                            <select name="presupuesto" class="form-select form-select-lg rounded-0 border-secondary shadow-none">
                                <option value="">Todos los presupuestos</option>
                                {# Se debe pasar 'presupuestos' desde el controlador #}
                            </select>

                        </div>

                        <div class="col-auto">

                            <button class="btn btn-dark rounded-0 px-4 h-100">
                                Buscar
                            </button>

                        </div>

                        <div class="col-auto">

                            <a href="{{ path('app_presupuestos_detalle_index') }}" class="btn btn-outline-secondary rounded-0 px-4 h-100">
                                Limpiar
                            </a>

                        </div>

                    </div>

                </form>

            </div>

            <div class="table-responsive">

                <table class="table align-middle mb-0">

                    <thead class="border-bottom">

                        <tr class="bg-dark">

                            <th class="text-black fw-normal border-0 p-3">
                                ID
                            </th>

                            <th class="text-black fw-normal border-0 p-3">
                                Presupuesto
                            </th>

                            <th class="text-black fw-normal border-0 p-3">
                                Producto
                            </th>

                            <th class="text-black fw-normal border-0 p-3">
                                Cantidad
                            </th>

                            <th class="text-black fw-normal border-0 p-3">
                                Precio Unit.
                            </th>

                            <th class="text-black fw-normal border-0 p-3">
                                Subtotal
                            </th>

                            <th class="text-black fw-normal border-0 p-3 text-end">
                                Acciones
                            </th>

                        </tr>

                    </thead>

                    <tbody>

                        {% for detalle in presupuestos_detalles %}

                            <tr class="border-top">

                                <td class="p-3 text-secondary">
                                    #{{ detalle.id }}
                                </td>

                                <td class="p-3">
                                    <div class="fw-medium text-dark">
                                        {{ detalle.presupuesto ? detalle.presupuesto.clienteNombre : 'N/A' }}
                                    </div>
                                    <small class="text-muted">
                                        {{ detalle.presupuesto ? detalle.presupuesto.fecha|date('d/m/Y') : '' }}
                                    </small>
                                </td>

                                <td class="p-3 text-secondary">
                                    {{ detalle.producto ? detalle.producto.nombre : 'N/A' }}
                                </td>

                                <td class="p-3 text-secondary">
                                    {{ detalle.cantidad|number_format(3, ',', '.') }}
                                </td>

                                <td class="p-3 text-secondary">
                                    ${{ detalle.precioUnitario|number_format(2, ',', '.') }}
                                </td>

                                <td class="p-3 text-success-emphasis">
                                    ${{ detalle.subtotal|number_format(2, ',', '.') }}
                                </td>

                                <td class="p-3 text-end">



                                    <a href="{{ path('app_presupuestos_detalle_edit', {'id': detalle.id}) }}" class="text-warning me-3" title="Editar">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <button type="button" class="btn btn-link text-danger p-0 m-0" style="border: none; background: none;" title="Eliminar" data-delete data-id="{{ detalle.id }}" data-name="Detalle #{{ detalle.id }}" data-url="{{ path('app_presupuestos_detalle_delete', {'id': 'ID_PLACEHOLDER'}) }}" data-token="{{ csrf_token('delete' ~ detalle.id) }}">
                                        <i class="bi bi-trash"></i>
                                    </button>

                                </td>

                            </tr>

                        {% else %}

                            <tr>
                                <td colspan="7" class="text-center py-5 text-secondary">
                                    No se encontraron detalles
                                </td>
                            </tr>

                        {% endfor %}

                    </tbody>

                </table>

            </div>

            <div class="card-footer bg-white border-0 py-4">

                <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                    <small class="text-secondary">
                        Total:
                        {{ presupuestos_detalles.getTotalItemCount }}
                        detalles
                    </small>

                    <nav>
                        <ul class="pagination pagination-sm mb-0">

                            {% if presupuestos_detalles.currentPageNumber > 1 %}
                                <li class="page-item">
                                    <a class="page-link rounded-0 text-dark shadow-none" href="{{ path('app_presupuestos_detalle_index', { page: presupuestos_detalles.currentPageNumber - 1 }) }}">
                                        &laquo;
                                    </a>
                                </li>
                            {% endif %}

                            {% set start = presupuestos_detalles.currentPageNumber - 1 %}
                            {% set end = presupuestos_detalles.currentPageNumber + 1 %}

                            {% if start < 1 %}
                                {% set start = 1 %}
                                {% set end = 3 %}
                            {% endif %}

                            {% if end > presupuestos_detalles.pageCount %}
                                {% set end = presupuestos_detalles.pageCount %}
                                {% set start = presupuestos_detalles.pageCount - 2 %}
                            {% endif %}

                            {% if start < 1 %}
                                {% set start = 1 %}
                            {% endif %}

                            {% for page in start..end %}
                                <li class="page-item {{ page == presupuestos_detalles.currentPageNumber ? 'active' : '' }}">
                                    <a class="page-link rounded-0 shadow-none {{ page == presupuestos_detalles.currentPageNumber ? 'bg-dark border-dark text-white' : 'text-dark' }}" href="{{ path('app_presupuestos_detalle_index', { page: page }) }}">
                                        {{ page }}
                                    </a>
                                </li>
                            {% endfor %}

                            {% if presupuestos_detalles.currentPageNumber < presupuestos_detalles.pageCount %}
                                <li class="page-item">
                                    <a class="page-link rounded-0 text-dark shadow-none" href="{{ path('app_presupuestos_detalle_index', { page: presupuestos_detalles.currentPageNumber + 1 }) }}">
                                        &raquo;
                                    </a>
                                </li>
                            {% endif %}

                        </ul>
                    </nav>

                </div>

            </div>

        </div>

    </div>

{% endblock %}
