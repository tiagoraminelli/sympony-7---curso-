{#
    Vista: presupuestos/index.html.twig
#}

{% extends 'base.html.twig' %}

{% block title %}Presupuestos
{% endblock %}

{% block body %}

    <div class="container py-5">

        <div class="mx-auto" style="max-width: 1150px;">

            <div class="d-flex justify-content-between align-items-center mb-4">

                <div>
                    <h1 class="display-6 fw-light text-dark mb-1" style="letter-spacing: -1px;">
                        Presupuestos
                    </h1>

                    <p class="text-secondary mb-0">
                        Gestión de presupuestos del sistema
                    </p>
                </div>

                <div class="d-flex gap-2">

                    <a href="{{ path('app_presupuestos_new') }}" class="btn btn-dark rounded-0 px-4 py-2">
                        <i class="bi bi-plus-lg"></i>
                        Nuevo Presupuesto
                    </a>

                </div>

            </div>

            <div class="card border-0 rounded-0 shadow-sm">

                <div class="card-body p-4 border-bottom bg-light">

                    <form method="GET" action="{{ path('app_presupuestos_index') }}">

                        <div class="row g-2 align-items-center">

                            <div class="col-md-5">

                                <input type="text" name="search" value="{{ search }}" class="form-control form-control-lg rounded-0 border-secondary shadow-none" placeholder="Buscar por cliente...">

                            </div>

                            <div class="col-md-3">

                                <select name="estado" class="form-select form-select-lg rounded-0 border-secondary shadow-none">
                                    <option value="">Todos los estados</option>
                                    <option value="borrador" {{ estado == 'borrador' ? 'selected' : '' }}>Borrador</option>
                                    <option value="enviado" {{ estado == 'enviado' ? 'selected' : '' }}>Enviado</option>
                                    <option value="aprobado" {{ estado == 'aprobado' ? 'selected' : '' }}>Aprobado</option>
                                    <option value="rechazado" {{ estado == 'rechazado' ? 'selected' : '' }}>Rechazado</option>
                                </select>

                            </div>

                            <div class="col-auto">

                                <button class="btn btn-dark rounded-0 px-4 h-100">
                                    Buscar
                                </button>

                            </div>

                            <div class="col-auto">

                                <a href="{{ path('app_presupuestos_index') }}" class="btn btn-outline-secondary rounded-0 px-4 h-100">
                                    Limpiar
                                </a>

                            </div>

                        </div>

                    </form>

                </div>

                <div class="table-responsive">

                    <table class="table align-middle mb-0">

                        <thead class="border-bottom">

                            <tr class="bg-dark">

                                <th class="text-black fw-normal border-0 p-3">
                                    ID
                                </th>

                                <th class="text-black fw-normal border-0 p-3">
                                    Cliente
                                </th>

                                <th class="text-black fw-normal border-0 p-3">
                                    Fecha
                                </th>

                                <th class="text-black fw-normal border-0 p-3">
                                    Total
                                </th>

                                <th class="text-black fw-normal border-0 p-3">
                                    Estado
                                </th>

                                <th class="text-black fw-normal border-0 p-3 text-end">
                                    Acciones
                                </th>

                            </tr>

                        </thead>

                        <tbody>

                            {% for presupuesto in presupuestos %}

                                <tr class="border-top">

                                    <td class="p-3 text-secondary">
                                        #{{ presupuesto.id }}
                                    </td>

                                    <td class="p-3">
                                        <div class="fw-medium text-dark">
                                            {{ presupuesto.clienteNombre }}
                                        </div>
                                        <small class="text-muted">
                                            {{ presupuesto.clienteTelefono ?: 'Sin teléfono' }}
                                        </small>
                                    </td>

                                    <td class="p-3 text-secondary">
                                        {{ presupuesto.fecha ? presupuesto.fecha|date('d/m/Y') : '-' }}
                                    </td>

                                    <td class="p-3 text-success-emphasis">
                                        ${{ presupuesto.total|number_format(2, ',', '.') }}
                                    </td>

                                    <td class="p-3">

                                        {% set estadoClass = {
                                            'borrador': 'bg-secondary',
                                            'enviado': 'bg-info text-dark',
                                            'aprobado': 'bg-success',
                                            'rechazado': 'bg-danger'
                                        } %}

                                        <span class="badge {{ estadoClass[presupuesto.estado] ?? 'bg-secondary' }} rounded-0 px-3 py-2 fw-normal">
                                            {{ presupuesto.estado|capitalize }}
                                        </span>

                                    </td>

                                    <td class="p-3 text-end">

                                        <a href="{{ path('app_presupuestos_show', {'id': presupuesto.id}) }}" class="text-primary me-3" title="Ver">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        <a href="{{ path('app_presupuestos_edit', {'id': presupuesto.id}) }}" class="text-warning me-3" title="Editar">
                                            <i class="bi bi-pencil-square"></i>
                                        </a>

                                        <button type="button" class="btn btn-link text-danger p-0 m-0" style="border: none; background: none;" title="Eliminar" data-delete data-id="{{ presupuesto.id }}" data-name="{{ presupuesto.clienteNombre }}" data-url="{{ path('app_presupuestos_delete', {'id': 'ID_PLACEHOLDER'}) }}" data-token="{{ csrf_token('delete' ~ presupuesto.id) }}">
                                            <i class="bi bi-trash"></i>
                                        </button>

                                    </td>

                                </tr>

                            {% else %}

                                <tr>

                                    <td colspan="6" class="text-center py-5 text-secondary">

                                        No se encontraron presupuestos

                                    </td>

                                </tr>

                            {% endfor %}

                        </tbody>

                    </table>

                </div>

                <div class="card-footer bg-white border-0 py-4">

                    <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

                        <small class="text-secondary">
                            Total:
                            {{ presupuestos.getTotalItemCount }}
                            presupuestos
                        </small>

                        <nav>

                            <ul class="pagination pagination-sm mb-0">

                                {% if presupuestos.currentPageNumber > 1 %}

                                    <li class="page-item">

                                        <a class="page-link rounded-0 text-dark shadow-none" href="{{ path('app_presupuestos_index', { page: presupuestos.currentPageNumber - 1, search: search, estado: estado }) }}">

                                            &laquo;

                                        </a>

                                    </li>

                                {% endif %}

                                {% set start = presupuestos.currentPageNumber - 1 %}
                                {% set end = presupuestos.currentPageNumber + 1 %}

                                {% if start < 1 %}
                                    {% set start = 1 %}
                                    {% set end = 3 %}
                                {% endif %}

                                {% if end > presupuestos.pageCount %}
                                    {% set end = presupuestos.pageCount %}
                                    {% set start = presupuestos.pageCount - 2 %}
                                {% endif %}

                                {% if start < 1 %}
                                    {% set start = 1 %}
                                {% endif %}

                                {% for page in start..end %}

                                    <li class="page-item {{ page == presupuestos.currentPageNumber ? 'active' : '' }}">

                                        <a class="page-link rounded-0 shadow-none {{ page == presupuestos.currentPageNumber ? 'bg-dark border-dark text-white' : 'text-dark' }}" href="{{ path('app_presupuestos_index', { page: page, search: search, estado: estado }) }}">

                                            {{ page }}

                                        </a>

                                    </li>

                                {% endfor %}

                                {% if presupuestos.currentPageNumber < presupuestos.pageCount %}

                                    <li class="page-item">

                                        <a class="page-link rounded-0 text-dark shadow-none" href="{{ path('app_presupuestos_index', { page: presupuestos.currentPageNumber + 1, search: search, estado: estado }) }}">

                                            &raquo;

                                        </a>

                                    </li>

                                {% endif %}

                            </ul>

                        </nav>

                    </div>

                </div>

            </div>

        </div>

    </div>

{% endblock %}
