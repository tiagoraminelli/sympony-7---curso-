{#
    Vista: productos/index.html.twig
#}

{% extends 'base.html.twig' %}

{% block title %}Productos
{% endblock %}

{% block body %}

	<div class="container py-5">

		<div class="mx-auto" style="max-width: 1150px;">

			<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h1 class="display-6 fw-light text-dark mb-1" style="letter-spacing: -1px;">
            Productos
        </h1>

        <p class="text-secondary mb-0">
            Manejo de productos registrados en el sistema
        </p>
    </div>

    <div class="d-flex gap-2">

        <a href="{{ path('app_productos_bulk_update') }}"
           class="btn btn-outline-secondary rounded-0 px-4 py-2">
            <i class="bi bi-pencil-square"></i>
            Edición Masiva
        </a>

        <a href="{{ path('app_productos_new') }}"
           class="btn btn-dark rounded-0 px-4 py-2">
            <i class="bi bi-plus-lg"></i>
            Nuevo Producto
        </a>
    </div>

</div>


			<div class="card border-0 rounded-0 shadow-sm">

				<div class="card-body p-4 border-bottom bg-light">

					<form method="GET" action="{{ path('app_productos_index') }}">

						<div class="row g-2 align-items-center">

							<div class="col">

								<input type="text" name="search" value="{{ search }}" class="form-control form-control-lg rounded-0 border-secondary shadow-none" placeholder="Buscar por nombre o descripción...">

							</div>

							<div class="col-md-3">

								<select name="categoria" class="form-select form-select-lg rounded-0 border-secondary shadow-none">
									<option value="">Todas las categorías</option>
									{% for categoria in categorias %}
										<option value="{{ categoria.id }}" {{ categoriaId == categoria.id ? 'selected' : '' }}>
											{{ categoria.nombre }}
										</option>
									{% endfor %}
								</select>

							</div>

							<div class="col-auto">

								<button class="btn btn-dark rounded-0 px-4 h-100">
									Buscar
								</button>

							</div>

							<div class="col-auto">

								<a href="{{ path('app_productos_index') }}" class="btn btn-outline-secondary rounded-0 px-4 h-100">
									Limpiar
								</a>

							</div>

						</div>

					</form>

				</div>

				<div class="table-responsive">

					<table class="table align-middle mb-0">

						<thead class="border-bottom">

							<tr class="bg-dark">

								<th class="text-black fw-normal border-0 p-3">
									ID
								</th>

								<th class="text-black fw-normal border-0 p-3">
									Nombre
								</th>

								<th class="text-black fw-normal border-0 p-3">
									Categoría
								</th>

								<th class="text-black fw-normal border-0 p-3">
									Costo
								</th>

								<th class="text-black fw-normal border-0 p-3">
									Precio
								</th>

								<th class="text-black fw-normal border-0 p-3">
									Stock
								</th>

								<th class="text-black fw-normal border-0 p-3 text-end">
									Acciones
								</th>

							</tr>

						</thead>

						<tbody>

							{% for producto in productos %}

								<tr class="border-top">

									<td class="p-3 text-secondary">
										#{{ producto.id }}
									</td>

									<td class="p-3">
										<div class="fw-medium text-dark">
											{{ producto.nombre }}
										</div>

										<small class="text-muted">
											{{ producto.descripcion }}
										</small>
									</td>

									<td class="p-3 text-secondary">
										{{ producto.categoria ? producto.categoria.nombre : 'Sin categoría' }}
									</td>

									<td class="p-3 text-danger-emphasis">
										${{ producto.precioCosto|number_format(2, ',', '.') }}
									</td>

									<td class="p-3 text-success-emphasis">
										${{ producto.precio|number_format(2, ',', '.') }}
									</td>

									<td class="p-3 text-secondary">
										{{ producto.stock }}
									</td>

									<td class="p-3 text-end">

										<a href="{{ path('app_productos_show', {'id': producto.id}) }}" class="text-primary me-3" title="Ver">
											<i class="bi bi-eye"></i>
										</a>

										<a href="{{ path('app_productos_edit', {'id': producto.id}) }}" class="text-warning me-3" title="Editar">
											<i class="bi bi-pencil-square"></i>
										</a>

										<button type="button" class="btn btn-link text-danger p-0 m-0" style="border: none; background: none;" title="Eliminar" data-delete data-id="{{ producto.id }}" data-name="{{ producto.nombre }}" data-url="{{ path('app_productos_delete', {'id': 'ID_PLACEHOLDER'}) }}" data-token="{{ csrf_token('delete' ~ producto.id) }}">
											<i class="bi bi-trash"></i>
										</button>

									</td>

								</tr>

							{% else %}

								<tr>

									<td colspan="7" class="text-center py-5 text-secondary">

										No se encontraron productos

									</td>

								</tr>

							{% endfor %}

						</tbody>

					</table>

				</div>

				<div class="card-footer bg-white border-0 py-4">

					<div class="d-flex justify-content-between align-items-center flex-wrap gap-3">

						<small class="text-secondary">
							Total:
							{{ productos.getTotalItemCount }}
							productos
						</small>

						<nav>

							<ul class="pagination pagination-sm mb-0">

								{% if productos.currentPageNumber > 1 %}

									<li class="page-item">

										<a class="page-link rounded-0 text-dark shadow-none" href="{{ path('app_productos_index', { page: productos.currentPageNumber - 1, search: search, categoria: categoriaId }) }}">

											&laquo;

										</a>

									</li>

								{% endif %}

								{% set start = productos.currentPageNumber - 1 %}
								{% set end = productos.currentPageNumber + 1 %}

								{% if start < 1 %}
									{% set start = 1 %}
									{% set end = 3 %}
								{% endif %}

								{% if end > productos.pageCount %}
									{% set end = productos.pageCount %}
									{% set start = productos.pageCount - 2 %}
								{% endif %}

								{% if start < 1 %}
									{% set start = 1 %}
								{% endif %}

								{% for page in start..end %}

									<li class="page-item {{ page == productos.currentPageNumber ? 'active' : '' }}">

										<a class="page-link rounded-0 shadow-none {{ page == productos.currentPageNumber ? 'bg-dark border-dark text-white' : 'text-dark' }}" href="{{ path('app_productos_index', { page: page, search: search, categoria: categoriaId }) }}">

											{{ page }}

										</a>

									</li>

								{% endfor %}

								{% if productos.currentPageNumber < productos.pageCount %}

									<li class="page-item">

										<a class="page-link rounded-0 text-dark shadow-none" href="{{ path('app_productos_index', { page: productos.currentPageNumber + 1, search: search, categoria: categoriaId }) }}">

											&raquo;

										</a>

									</li>

								{% endif %}

							</ul>

						</nav>

					</div>

				</div>

			</div>

		</div>

	</div>

{% endblock %}
